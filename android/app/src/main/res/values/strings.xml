    <string name="about_title">About aus-roads</string>
    <string name="about_back">Back</string>
    <string name="about_section_app">App</string>
    <string name="about_app_license">aus-roads v0.1.0\nCopyright © 2026 benbi.\nLicensed under the GNU Affero General Public License v3.0 or later (AGPL-3.0-or-later).\nSee the project repository for the full license text.</string>
