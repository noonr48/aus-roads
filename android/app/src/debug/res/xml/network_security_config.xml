<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG ONLY. Permits cleartext (HTTP) traffic to loopback hosts so the local
  map-pack demo server (tools/map-pack-builder/scripts/serve-pack.sh, reached via
  `adb reverse tcp:8080 tcp:8080`) works in debug builds.

  This lives in src/debug, so RELEASE builds have NO network-security override and
  keep Android's default cleartext-blocked posture — all real traffic (the
  production CDN over HTTPS) is unaffected and the privacy posture is preserved.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
